[Unit]
Description=VPN Redis Checker + Dashboard
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/vpn_checker
ExecStart=/opt/vpn_checker/redis-checker -recheck -workers 10 -timeout 15s -serve :8080
Restart=on-failure
RestartSec=5s

Environment=REDIS_URL=redis://default:PASSWORD@HOST:PORT
Environment=PUBLIC_HOST=YOUR_VDS_IP

# Logs: journalctl -u redis-checker -f
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
